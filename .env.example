APP_NAME="Dherhiel Portfolio"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# This portfolio is static content driven by config/portfolio.php,
# so a database is optional. Defaults left here for a standard Laravel setup.
DB_CONNECTION=sqlite

SESSION_DRIVER=file
QUEUE_CONNECTION=sync
CACHE_STORE=file
